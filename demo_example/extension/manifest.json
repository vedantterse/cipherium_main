{
  "manifest_version": 3,
  "name": "Cipherium",
  "description": "Capture chat screenshots and detect phishing with AI",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cipherium — Capture & Analyze"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/dashboard*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
